# =============================================================================
# SECURITY: This file MUST be committed before any secrets or sensitive files.
# Rule: Never commit .env or API keys. Violations affect grade (per rubric 5b).
# =============================================================================

# --- Secrets & Environment Variables ---
# CRITICAL: .env contains real API keys — never commit this file
.env
.env.*
.env.local
.env.*.local

# --- GCP Service Account Keys ---
# CRITICAL: JSON key files grant full GCP access — never commit these
*-key.json
*_key.json
*-credentials.json
*_credentials.json
*-service-account.json
gcp-key.json
**/gcp-key.json
*.pem

# --- Python ---
# Exclude compiled bytecode and virtual environments
__pycache__/
*.py[cod]
*.pyo
*.pyd
venv/
.venv/
env/
*.egg-info/
dist/
build/
.pytest_cache/
*.egg

# --- Node.js ---
# Exclude installed packages (use package.json to reinstall)
node_modules/
.next/
npm-debug.log*
yarn-error.log*
.npm/

# --- Jupyter Notebooks ---
# Exclude checkpoint files generated during notebook use
.ipynb_checkpoints/

# --- macOS ---
# Exclude macOS system files
.DS_Store
.AppleDouble
.LSOverride

# --- IDEs & Editors ---
# Exclude editor-specific config that should not be shared
.vscode/settings.json
.idea/
*.swp
*.swo

# --- Claude Code ---
# Local Claude Code config (machine-specific paths)
.claude/

# --- Data: Large Files ---
# Files over 10MB should not be committed (use download scripts instead per rubric 5b)
# Add specific large file patterns here as needed
*.csv.gz
*.parquet

# --- Build Outputs ---
*.log
