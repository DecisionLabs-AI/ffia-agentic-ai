# =============================================================================
# SECURITY: This is a TEMPLATE file — safe to commit.
# Copy this file to .env and fill in your real keys.
# NEVER commit the actual .env file (it is in .gitignore).
# =============================================================================

# --- LLM: Anthropic Claude (required) ---
# Get your key at: https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Oil Price Data: EPPO (Thailand Energy Regulatory Commission) ---
# Public data source — may not require a key for CSV download
# Endpoint: https://www.eppo.go.th/index.php/en/petroleum/oil-price
EPPO_API_KEY=your_eppo_api_key_here_if_required

# --- Maps & Routing (optional for delivery cost estimation) ---
# Google Maps API: https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# --- Delivery Platform Costs (optional) ---
# Used for estimating fuel surcharge embedded in delivery fees
DELIVERY_API_KEY=your_delivery_api_key_here
