# =============================================================================
# SECURITY: This is a TEMPLATE file — safe to commit.
# Copy this file to .env and fill in your real values.
# NEVER commit the actual .env file (it is in .gitignore).
# =============================================================================

# --- LLM: Google AI API key (required) ---
# Get your key at https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=your_gemini_api_key_here

# --- Database: PostgreSQL connection URL (required) ---
# Format: postgresql://user:password@host:5432/dbname
# Example (Supabase): postgresql://postgres:password@db.xxxx.supabase.co:5432/postgres
# Example (Neon):     postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Web Search: Tavily (optional — upgrades from DuckDuckGo to Tavily automatically) ---
# Register at https://tavily.com/ to get a key. Leave blank to use DuckDuckGo (free).
# TAVILY_API_KEY=your_tavily_api_key_here

# --- Future / Optional ---
# EPPO_API_KEY=your_eppo_api_key_here_if_required
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
# DELIVERY_API_KEY=your_delivery_api_key_here
