# =============================================================================
# FFIA — Environment Variable Template
# SECURITY: This file is safe to commit. Copy to .env and fill in real values.
# NEVER commit the actual .env file (it is in .gitignore).
# =============================================================================
# REQUIRED before first run:
#   1. GCP_PROJECT_ID          — your Google Cloud project ID
#   2. GCP_SERVICE_ACCOUNT_JSON — service account key as a single-line JSON string
#                                  (local dev alternative: set GOOGLE_APPLICATION_CREDENTIALS
#                                   to the file path instead, then leave this blank)
#   3. DATABASE_URL            — PostgreSQL connection string
#   4. JWT_SECRET              — signing key for JWTs (required when ENVIRONMENT=production)
#   5. FFIA_AUTH_USERS_JSON    — at least one login user with a real password hash
# =============================================================================

# --- Runtime environment ---
# Set to "production" on Cloud Run to enforce JWT_SECRET and other safety checks.
ENVIRONMENT=development

# --- GCP / Vertex AI (required) ---
GCP_PROJECT_ID=your-gcp-project-id

# Service account JSON as a single-line string (Cloud Run / Streamlit Cloud).
# Generate with: cat gcp-key.json | tr -d '\n'
# Local dev alternative: set GOOGLE_APPLICATION_CREDENTIALS to the file path and leave this blank.
GCP_SERVICE_ACCOUNT_JSON=

# Vertex AI region — asia-southeast1 (Singapore) is closest to Bangkok.
VERTEX_LOCATION=asia-southeast1

# Gemini model used by both the ReAct agent and the OCR invoice reader.
# No separate FFIA_OCR_MODEL exists yet; both services share this setting.
FFIA_AGENT_MODEL=gemini-2.5-flash

# --- Database: PostgreSQL (required) ---
# Format: postgresql://user:password@host:5432/dbname
# Add ?sslmode=require for Supabase, Neon, or any cloud-hosted PostgreSQL.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Authentication (required) ---
# Generate a strong secret: python3 -c "import secrets; print(secrets.token_hex(32))"
# If ENVIRONMENT=production and this is blank, the app will refuse to start.
JWT_SECRET=

# Login users as a JSON array. Each entry: username, display_name, password_hash.
# password_hash format: pbkdf2_sha256$iterations$salt_hex$hash_hex
# Generate a hash: python3 -c "from app.utils.auth import hash_password; print(hash_password('yourpassword'))"
FFIA_AUTH_USERS_JSON=[{"username":"admin","display_name":"Admin","password_hash":"pbkdf2_sha256$390000$aabbccddeeff00112233445566778899$609b47175963150c6f4fcc9dc6c88dc8927d66f60b79e56f626f78a21c0e4eba"}]

# --- CORS (required) ---
# Comma-separated list of allowed frontend origins (no trailing slash).
CORS_ORIGINS=http://localhost:3000

# --- Optional ---
# Tavily API key — better web search quality; falls back to DuckDuckGo if unset.
# TAVILY_API_KEY=

# Agent timeout in seconds (default: 60). Increase on Cloud Run for complex queries.
FFIA_AGENT_TIMEOUT_SECONDS=90

# Demo user ID for unauthenticated dashboard endpoint (default: demo).
FFIA_DEMO_USER_ID=demo

# Assign pre-tenant legacy invoices to this username on first migration.
# If omitted and exactly one auth user exists, assigned automatically.
# FFIA_LEGACY_OWNER_USERNAME=admin
