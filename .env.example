# =============================================================================
# SECURITY: This is a TEMPLATE file — safe to commit.
# Copy this file to .env and fill in your real values.
# NEVER commit the actual .env file (it is in .gitignore).
# =============================================================================

# --- LLM + BigQuery: Google Cloud (required for W2+) ---
# Path to your GCP service account JSON key file (download from GCP Console → IAM → Service Accounts)
# The service account needs: BigQuery Data Viewer, BigQuery Job User, Vertex AI User roles
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your/service-account-key.json

# GCP Project ID
GOOGLE_CLOUD_PROJECT=gcp-madt-ai

# BigQuery dataset name
BIGQUERY_DATASET=data_source

# BigQuery dataset region
BIGQUERY_LOCATION=asia-southeast3

# --- Web Search: Tavily (optional — upgrades from DuckDuckGo to Tavily automatically) ---
# Register at https://tavily.com/ to get a key. Leave blank to use DuckDuckGo (free).
# TAVILY_API_KEY=your_tavily_api_key_here

# --- W1 only (no longer used in W2+) ---
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Future / Optional ---
# EPPO_API_KEY=your_eppo_api_key_here_if_required
# GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
# DELIVERY_API_KEY=your_delivery_api_key_here
