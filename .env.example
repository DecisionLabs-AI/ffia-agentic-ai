# =============================================================================
# SECURITY: This is a TEMPLATE file â€” safe to commit.
# Copy this file to .env and fill in your real values.
# NEVER commit the actual .env file (it is in .gitignore).
# =============================================================================
# REQUIRED before first run:
#   1. GOOGLE_APPLICATION_CREDENTIALS â€” path to your GCP service account key JSON
#   2. GCP_PROJECT_ID  â€” your Google Cloud project ID
#   3. DATABASE_URL    â€” your PostgreSQL connection string
#   4. FFIA_AUTH_USERS_JSON â€” at least one login user with a real password hash
#      (generate a hash: python3 -c "from app.utils.auth import hash_password; print(hash_password('yourpassword'))")
# =============================================================================

# --- LLM: Vertex AI credentials (required) ---
# Point to your service account key file (e.g. gcp-key.json in project root)
GOOGLE_APPLICATION_CREDENTIALS=./gcp-key.json
# Your GCP project ID (visible in the Google Cloud Console top bar)
GCP_PROJECT_ID=your-gcp-project-id
# Vertex AI region â€” asia-southeast1 (Singapore) is closest to Bangkok
GCP_LOCATION=asia-southeast1

# --- Database: PostgreSQL connection URL (required) ---
# Format: postgresql://user:password@host:5432/dbname
# Supabase session pooler: postgresql://postgres.xxxx:password@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres
# Neon:                    postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb
DATABASE_URL=postgresql://user:password@host:5432/dbname

# --- Authentication / Tenant Isolation (required) ---
# Configure one or more FFIA login users as a JSON array.
# Each entry must have: username, display_name, password_hash
# The username is also used as the tenant user_id for data scoping.
#
# password_hash format: pbkdf2_sha256$iterations$salt_hex$hash_hex
#
# Generate a hash for your own password:
#   python3 -c "from app.utils.auth import hash_password; print(hash_password('yourpassword'))"
#
# The example hash below is for the EXAMPLE password "changeme" â€” REPLACE before use.
FFIA_AUTH_USERS_JSON=[{"username":"admin","display_name":"Admin","password_hash":"pbkdf2_sha256$390000$aabbccddeeff00112233445566778899$609b47175963150c6f4fcc9dc6c88dc8927d66f60b79e56f626f78a21c0e4eba"}]

# Multi-user example (uncomment and extend as needed):
# FFIA_AUTH_USERS_JSON=[
#   {"username":"admin","display_name":"Admin","password_hash":"pbkdf2_sha256$390000$aabbccddeeff00112233445566778899$609b47175963150c6f4fcc9dc6c88dc8927d66f60b79e56f626f78a21c0e4eba"},
#   {"username":"alice","display_name":"Alice","password_hash":"pbkdf2_sha256$390000$<your_salt>$<your_hash>"}
# ]

# Optional: assign pre-tenant legacy invoices (no user_id) to this username on migration.
# If omitted and exactly one auth user exists, FFIA assigns legacy rows to that user automatically.
# FFIA_LEGACY_OWNER_USERNAME=admin

# --- Web Search: Tavily (optional) ---
# Leave blank to use DuckDuckGo (free, no key needed).
# Register at https://tavily.com/ for better search quality.
# TAVILY_API_KEY=your_tavily_api_key_here
